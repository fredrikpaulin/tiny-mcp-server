{
  "name": "tiny-mcp-server",
  "version": "0.4.2",
  "description": "Modular toolkit for building MCP servers on Bun — persistent context graph, incremental code scanning, full-text search, and built-in input validation",
  "author": "Fredrik Paulin <fredrik@rymdskepp.com>",
  "license": "MIT",
  "keywords": [
    "mcp",
    "server",
    "bun",
    "model-context-protocol",
    "anthropic",
    "claude"
  ],
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp.ts",
    "./modules/*": "./src/modules/*.ts",
    "./analyzer/*": "./src/analyzer/*.js"
  },
  "files": [
    "src/mcp.ts",
    "src/index.ts",
    "src/modules/recall.ts",
    "src/modules/patterns.ts",
    "src/modules/beacon.ts",
    "src/modules/scanner.ts",
    "src/modules/query.ts",
    "src/modules/export.ts",
    "src/modules/diff.ts",
    "src/modules/stats.ts",
    "src/modules/refactor.ts",
    "src/modules/prompt.ts",
    "src/analyzer/parser.js",
    "src/analyzer/ast.js",
    "src/analyzer/lexer.js",
    "src/analyzer/tokens.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredrikpaulin/tiny-mcp-server.git"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
